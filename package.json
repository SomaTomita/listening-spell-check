{
  "name": "spell-practice-listening",
  "version": "1.0.0",
  "private": true,
  "description": "IELTS listening spelling practice (local server + Vite React TS)",
  "type": "module",
  "scripts": {
    "dev:server": "nodemon --watch server --exec ts-node --esm server/app.ts",
    "dev:client": "vite --config client/vite.config.ts client",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build --config client/vite.config.ts client",
    "format": "prettier -w .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^7.1.12"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^6.1.7",
    "@vitejs/plugin-react": "^4.3.2",
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "say": "^0.16.0"
  }
}
